{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "baseline",
  "version": "0.1.0",
  "identifier": "com.baseline.editor",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Baseline",
        "width": 1000,
        "height": 650,
        "minWidth": 600,
        "minHeight": 400,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "decorations": false,
        "fullscreen": false,
        "alwaysOnTop": false,
        "transparent": false,
        "resizable": true,
        "maximized": false

      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
